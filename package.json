{
  "name": "loclone",
  "version": "0.1.0",
  "private": true,
  "description": "Loclone — AI website clone platform with dashboard, QA, and handoff",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "website-clone",
    "reverse-engineering",
    "nextjs",
    "ai",
    "template",
    "tailwindcss",
    "shadcn-ui"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
