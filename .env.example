# Loclone environment (copy to .env.local)

LOCLONE_AUTH_MODE=dev

# Neon PostgreSQL (프로덕션/Vercel 필수 — 미설정 시 storage/loclone-db.json)
# DATABASE_URL=postgresql://...@...neon.tech/neondb?sslmode=require

# Clone Worker (render/mirror/spa modes)
# CLONE_WORKER_URL=http://localhost:3100

# Vercel Blob — 클론 HTML/에셋 영구 저장 (Vercel Dashboard → Storage → Blob)
# Marketplace: vercel integration add blob
# BLOB_READ_WRITE_TOKEN=

# Optional — Vercel deploy
# VERCEL_TOKEN=

# Optional — PageSpeed API
# GOOGLE_PAGESPEED_API_KEY=
